# Flask Service URL
FLASK_URL=http://localhost:5000

# Server Port
PORT=3003

# GitHub API (Optional - increases rate limit)
GITHUB_TOKEN=

# Jira Cloud
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
JIRA_BOARD_ID=

# PostgreSQL
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/focusflow

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3003
